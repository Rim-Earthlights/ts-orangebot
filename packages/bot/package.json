{
    "name": "@orangebot/bot",
    "version": "1.0.0",
    "description": "Discord Bot for Orange-Server",
    "type": "module",
    "main": "dist/app.js",
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "dev": "nodemon -x \"pnpm run start:dev\" -w src/app.ts -e ts,json",
        "start:dev": "node --import 'data:text/javascript,import { register } from \"node:module\"; import { pathToFileURL } from \"node:url\"; register(\"ts-node/esm\", pathToFileURL(\"./\"));' src/app.ts",
        "start": "FFMPEG_PATH=/usr/bin/ffmpeg node --import 'data:text/javascript,import { register } from \"node:module\"; import { pathToFileURL } from \"node:url\"; register(\"ts-node/esm\", pathToFileURL(\"./\"));' dist/app.js",
        "smoke-test": "node --import 'data:text/javascript,import { register } from \"node:module\"; import { pathToFileURL } from \"node:url\"; register(\"ts-node/esm\", pathToFileURL(\"./\"));' scripts/smoke-test.ts"
    },
    "dependencies": {
        "@orangebot/shared": "workspace:*",
        "@discordjs/opus": "^0.10.0",
        "@discordjs/voice": "^0.18.0",
        "@distube/ytdl-core": "^4.16.12",
        "@types/axios": "^0.14.0",
        "@types/body-parser": "^1.19.6",
        "@types/cors": "^2.8.19",
        "@types/ejs": "^3.1.1",
        "@types/express": "^5.0.3",
        "@types/node": "^24.0.14",
        "@types/node-cron": "^3.0.7",
        "@types/passport": "^1.0.11",
        "@types/react": "^19.1.8",
        "@types/sharp": "^0.32.0",
        "@types/typescript": "^2.0.0",
        "@types/vue": "^2.0.0",
        "axios": "^1.10.0",
        "body-parser": "^2.2.0",
        "cors": "^2.8.5",
        "dayjs": "^1.11.3",
        "discord-api-types": "^0.38.16",
        "discord-player-plus": "^2.0.5",
        "discord.js": "^14.21.0",
        "dotenv": "^17.2.0",
        "ejs": "^3.1.8",
        "express": "^5.1.0",
        "helmet": "^8.1.0",
        "iconv-lite": "^0.6.3",
        "jsdom": "^26.1.0",
        "mariadb": "^3.4.4",
        "mysql2": "^3.14.2",
        "node-cron": "^4.2.1",
        "nodemon": "^3.1.10",
        "openai": "^5.10.1",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.0",
        "passport-local": "^1.0.0",
        "prettier": "^3.6.2",
        "prism-media": "^1.3.5",
        "reflect-metadata": "^0.2.2",
        "sharp": "^0.34.3",
        "ts-node": "^10.9.2",
        "tweetnacl": "^1.0.3",
        "typeorm": "^0.3.25",
        "typescript": "^5.8.3",
        "ytpl": "^2.3.0",
        "ytsr": "^3.8.0"
    },
    "devDependencies": {
        "@types/jsdom": "^21.1.7",
        "@typescript-eslint/eslint-plugin": "^8.37.0",
        "@typescript-eslint/parser": "^8.37.0",
        "eslint": "^9.31.0",
        "eslint-config-google": "^0.14.0",
        "eslint-config-prettier": "^10.1.5"
    }
}
