{
    "name": "ts-orangebot",
    "version": "1.0.0",
    "description": "[TypeScript] Discord Bot for Orange-Server.",
    "author": "Rim Earthlights",
    "license": "MIT",
    "private": true,
    "scripts": {
        "build": "pnpm -r build",
        "clean": "pnpm -r clean",
        "dev": "pnpm --filter @orangebot/bot dev",
        "dev:speak": "pnpm --filter @orangebot/speak dev",
        "lint": "pnpm --filter @orangebot/bot lint",
        "smoke-test": "pnpm --filter @orangebot/bot smoke-test",
        "test": "pnpm -r test",
        "test:integration": "pnpm -r test:integration",
        "test:db:up": "docker compose -f docker-compose.test.yml up -d",
        "test:db:down": "docker compose -f docker-compose.test.yml down -v"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@discordjs/opus",
            "ffmpeg-static",
            "sharp"
        ]
    },
    "devDependencies": {
        "license-checker": "^25.0.1"
    }
}
